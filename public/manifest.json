{
  "manifest_version": 3,
  "name": "错题本 - AI 辅助学习",
  "version": "0.1.0",
  "description": "截图识别题目，智能整理错题，帮助备考",
  "permissions": ["storage"],
  "host_permissions": [
    "https://dashscope.aliyuncs.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "错题本"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
